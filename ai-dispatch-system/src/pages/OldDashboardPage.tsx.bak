import React, { useState, useEffect, useRef, useMemo } from 'react';
import { Link } from 'react-router-dom';
import { rawEmployees, platforms } from '../data/mockData';
import { calculateAiScores, assignGroups, calcHealthScore } from '../engine/aiEngine';
import ThreeDataCore from '../components/ThreeDataCore';

/* ═══════════════════════════════════════════════════════════
   BIOTECH LIVING CSS — injected as style tag
   ═══════════════════════════════════════════════════════════ */
const BIOTECH_CSS = `
  @keyframes bio-heartbeat {
    0%,100% { transform: scale(1); opacity: 0.85; }
    14% { transform: scale(1.12); opacity: 1; filter: brightness(1.3) drop-shadow(0 0 24px #00e5ff88); }
    28% { transform: scale(0.97); opacity: 0.9; }
    42% { transform: scale(1.07); opacity: 1; filter: brightness(1.2); }
  }
  @keyframes bio-breathe {
    0%,100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.06); opacity: 1; }
  }
  @keyframes bio-breathe-slow {
    0%,100% { transform: scale(1) translateY(0); opacity: 0.6; }
    50% { transform: scale(1.04) translateY(-4px); opacity: 0.95; }
  }
  @keyframes bio-vein-pulse {
    0%,100% { stroke-opacity: 0.3; stroke-width: 1.2; }
    50% { stroke-opacity: 1; stroke-width: 2.2; filter: drop-shadow(0 0 6px #00ffd088); }
  }
  @keyframes bio-synapse {
    0% { opacity: 0; r: 1; }
    40% { opacity: 1; r: 4; }
    80% { opacity: 0.4; r: 7; }
    100% { opacity: 0; r: 10; }
  }
  @keyframes bio-cell-divide {
    0% { transform: scale(1) rotate(0deg); }
    25% { transform: scale(1.15) rotate(3deg); }
    50% { transform: scale(0.95) rotate(-2deg); }
    75% { transform: scale(1.08) rotate(1deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  @keyframes bio-data-stream {
    0% { stroke-dashoffset: 200; opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 0.8; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }
  @keyframes bio-particle-rise {
    0% { transform: translateY(0) translateX(0) scale(1); opacity: 0.9; }
    100% { transform: translateY(-80px) translateX(var(--drift)) scale(0.2); opacity: 0; }
  }
  @keyframes bio-membrane-glow {
    0%,100% { box-shadow: 0 0 20px rgba(0,229,200,0.15), inset 0 0 30px rgba(0,229,200,0.05); }
    50% { box-shadow: 0 0 55px rgba(0,229,200,0.4), inset 0 0 50px rgba(0,229,200,0.12), 0 0 100px rgba(100,0,255,0.12); }
  }
  @keyframes bio-orbit-dna {
    0% { transform: translate(-50%,-50%) rotate(0deg) rotateX(65deg); }
    100% { transform: translate(-50%,-50%) rotate(360deg) rotateX(65deg); }
  }
  @keyframes bio-orbit-dna2 {
    0% { transform: translate(-50%,-50%) rotate(360deg) rotateX(65deg) rotateZ(45deg); }
    100% { transform: translate(-50%,-50%) rotate(0deg) rotateX(65deg) rotateZ(45deg); }
  }
  @keyframes bio-scan-sweep {
    0% { transform: translate(-50%,-50%) rotate(0deg); opacity: 0.7; }
    100% { transform: translate(-50%,-50%) rotate(360deg); opacity: 0.7; }
  }
  @keyframes bio-number-throb {
    0%,100% { transform: scale(1); text-shadow: 0 0 10px rgba(0,255,200,0.4); }
    50% { transform: scale(1.03); text-shadow: 0 0 30px rgba(0,255,200,0.9), 0 0 60px rgba(0,200,255,0.4); }
  }
  @keyframes bio-gauge-expand {
    0%,100% { transform: scaleX(1); opacity: 0.8; }
    50% { transform: scaleX(1.04); opacity: 1; filter: brightness(1.3); }
  }
  @keyframes bio-petri-float {
    0%,100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-6px) rotate(0.5deg); }
    66% { transform: translateY(-3px) rotate(-0.5deg); }
  }
  @keyframes bio-godray {
    0%,100% { opacity: 0.04; transform: translateX(-50%) skewX(-12deg) scaleX(1); }
    50% { opacity: 0.12; transform: translateX(-50%) skewX(-12deg) scaleX(1.15); }
  }
  @keyframes bio-hue-cycle {
    0% { filter: hue-rotate(0deg) brightness(1); }
    50% { filter: hue-rotate(30deg) brightness(1.1); }
    100% { filter: hue-rotate(0deg) brightness(1); }
  }
  @keyframes bio-city-ping {
    0% { r: 3; opacity: 1; }
    100% { r: 14; opacity: 0; }
  }
  @keyframes bio-neural-flash {
    0%,100% { opacity: 0.1; }
    50% { opacity: 0.9; stroke-width: 2.5; filter: drop-shadow(0 0 5px #00ffd0); }
  }
  @keyframes bio-float-particle {
    0% { opacity: 0; transform: translate(0,0) scale(0.5); }
    30% { opacity: 1; }
    100% { opacity: 0; transform: translate(var(--px),var(--py)) scale(1.5); }
  }
  @keyframes bio-dna-helix-shift {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -60; }
  }
  @keyframes bio-vitality-pulse {
    0%,100% { filter: brightness(1) drop-shadow(0 0 6px #00ffa040); }
    50% { filter: brightness(1.5) drop-shadow(0 0 20px #00ffa0cc); }
  }
  @keyframes bio-revenue-flow {
    0% { transform: translateY(20px); opacity: 0; }
    30% { opacity: 1; }
    100% { transform: translateY(-60px); opacity: 0; }
  }
  .bio-heartbeat { animation: bio-heartbeat 1.8s ease-in-out infinite; }
  .bio-breathe { animation: bio-breathe 3.5s ease-in-out infinite; }
  .bio-breathe-slow { animation: bio-breathe-slow 5s ease-in-out infinite; }
  .bio-number-throb { animation: bio-number-throb 2s ease-in-out infinite; }
  .bio-petri-float { animation: bio-petri-float 6s ease-in-out infinite; }
  .bio-membrane { animation: bio-membrane-glow 4s ease-in-out infinite; }
  .bio-hue-cycle { animation: bio-hue-cycle 8s ease-in-out infinite; }
`;

/* ─── Sub-components ─── */

const BioParticle = ({ x, y, color, delay }: { x: number; y: number; color: string; delay: string }) => (
  <div className="absolute pointer-events-none rounded-full"
    style={{
      left: x, top: y, width: 3, height: 3,
      background: color,
      boxShadow: `0 0 6px ${color}`,
      '--px': `${(Math.random() - 0.5) * 40}px`,
      '--py': `${-(Math.random() * 50 + 20)}px`,
      animation: `bio-float-particle ${2 + Math.random() * 3}s ease-out ${delay} infinite`,
    } as React.CSSProperties}
  />
);

const GoldParticle = ({ delay, left }: { delay: string; left: string }) => (
  <div className="absolute bottom-0 w-1 h-1 rounded-full pointer-events-none"
    style={{
      left,
      background: 'radial-gradient(circle, #ffd700, #ff9500)',
      boxShadow: '0 0 6px #ffd700aa',
      animation: `bio-revenue-flow ${1.8 + Math.random() * 2}s ease-out ${delay} infinite`,
    }}
  />
);

/* Live counter that grows like a living organism */
const useGrowingCounter = (start: number, rate: number, interval: number) => {
  const [val, setVal] = useState(start);
  useEffect(() => {
    const t = setInterval(() => setVal(p => p + Math.floor(Math.random() * rate + rate * 0.4)), interval);
    return () => clearInterval(t);
  }, [rate, interval]);
  return val;
};

/* City neural nodes */
const CITIES = [
  { name: '東京', cx: 295, cy: 100, color: '#00e5ff', delay: 0 },
  { name: '倫敦', cx: 130, cy: 108, color: '#7c4dff', delay: 0.4 },
  { name: '紐約', cx: 72, cy: 175, color: '#00ffa0', delay: 0.8 },
  { name: '巴黎', cx: 155, cy: 68, color: '#ff6ec7', delay: 1.2 },
  { name: '悉尼', cx: 310, cy: 265, color: '#ffd700', delay: 1.6 },
  { name: '上海', cx: 290, cy: 168, color: '#00e5ff', delay: 2.0 },
];

/* ═══════════════════════════════════════════════════════════
   BIO-SPHERE SVG — living neural globe
   ═══════════════════════════════════════════════════════════ */
const Biosphere = ({ liveMetric }: { liveMetric: number }) => {
  const cx = 190, cy = 190, R = 190;
  const synapseRef = useRef<SVGCircleElement[]>([]);
  const [synapseCities, setSynapseCities] = useState([0, 2, 4]);

  useEffect(() => {
    const t = setInterval(() => {
      setSynapseCities([
        Math.floor(Math.random() * 6),
        Math.floor(Math.random() * 6),
        Math.floor(Math.random() * 6),
      ]);
    }, 600);
    return () => clearInterval(t);
  }, []);

  return (
    <svg viewBox="0 0 380 380" className="w-full h-full" style={{ overflow: 'visible' }}>
      <defs>
        {/* Bio glow filter */}
        <filter id="bio-glow">
          <feGaussianBlur stdDeviation="3.5" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <filter id="bio-glow-strong">
          <feGaussianBlur stdDeviation="6" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <filter id="bio-plasma">
          <feTurbulence type="fractalNoise" baseFrequency="0.05 0.05" numOctaves="3" result="turb">
            <animate attributeName="seed" from="0" to="100" dur="6s" repeatCount="indefinite" />
          </feTurbulence>
          <feDisplacementMap in="SourceGraphic" in2="turb" scale="8" xChannelSelector="R" yChannelSelector="G" />
        </filter>

        {/* Radial gradients for sphere */}
        <radialGradient id="bio-sphere-grad" cx="35%" cy="30%" r="65%">
          <stop offset="0%" stopColor="#00ffd0" stopOpacity="0.18" />
          <stop offset="40%" stopColor="#00a0ff" stopOpacity="0.08" />
          <stop offset="80%" stopColor="#4400ff" stopOpacity="0.12" />
          <stop offset="100%" stopColor="#000" stopOpacity="0.6" />
        </radialGradient>
        <radialGradient id="bio-core-grad" cx="40%" cy="35%" r="60%">
          <stop offset="0%" stopColor="#aaffee" stopOpacity="1" />
          <stop offset="35%" stopColor="#00e5ff" stopOpacity="0.8" />
          <stop offset="70%" stopColor="#0055aa" stopOpacity="0.6" />
          <stop offset="100%" stopColor="#000820" stopOpacity="0.9" />
        </radialGradient>
        <radialGradient id="bio-membrane-grad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stopColor="#00ffd0" stopOpacity="0.0" />
          <stop offset="75%" stopColor="#00ffd0" stopOpacity="0.06" />
          <stop offset="100%" stopColor="#00ffd0" stopOpacity="0.25" />
        </radialGradient>
        <linearGradient id="bio-vein-1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stopColor="#00ffd0" stopOpacity="0.9" />
          <stop offset="100%" stopColor="#7c4dff" stopOpacity="0.6" />
        </linearGradient>
        <linearGradient id="bio-vein-2" x1="100%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stopColor="#ffd700" stopOpacity="0.9" />
          <stop offset="100%" stopColor="#00e5ff" stopOpacity="0.5" />
        </linearGradient>
        <linearGradient id="bio-vein-3" x1="0%" y1="100%" x2="100%" y2="0%">
          <stop offset="0%" stopColor="#ff6ec7" stopOpacity="0.7" />
          <stop offset="100%" stopColor="#00ffa0" stopOpacity="0.5" />
        </linearGradient>
        <radialGradient id="bio-scan-grad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stopColor="#00ffd0" stopOpacity="0.5" />
          <stop offset="60%" stopColor="#00ffd0" stopOpacity="0.2" />
          <stop offset="100%" stopColor="#00ffd0" stopOpacity="0" />
        </radialGradient>
        <mask id="sphere-mask">
          <circle cx={cx} cy={cy} r={R - 5} fill="white" />
        </mask>
      </defs>

      {/* ── Outer bio-membrane rings ── */}
      {[R + 28, R + 50, R + 72].map((r, i) => (
        <circle key={i} cx={cx} cy={cy} r={r} fill="none"
          stroke={['#00ffd0', '#7c4dff', '#00e5ff'][i]}
          strokeOpacity={[0.12, 0.08, 0.05][i]}
          strokeWidth={[2, 1.5, 1][i]}
          strokeDasharray={i === 0 ? "3 7" : i === 1 ? "8 20" : "1 12"}
          style={{ animation: `${i % 2 === 0 ? 'bio-orbit-dna' : 'bio-orbit-dna2'} ${22 + i * 12}s linear infinite`, transformOrigin: `${cx}px ${cy}px` }}
        />
      ))}

      {/* ── Cellular lattice over sphere (grid mesh) ── */}
      <g mask="url(#sphere-mask)" opacity="0.18">
        {Array.from({ length: 9 }, (_, i) => (
          <line key={`h${i}`} x1={cx - R} y1={cy - R + i * (R * 2 / 8)} x2={cx + R} y2={cy - R + i * (R * 2 / 8)}
            stroke="#00ffd0" strokeWidth="0.4" />
        ))}
        {Array.from({ length: 9 }, (_, i) => (
          <line key={`v${i}`} x1={cx - R + i * (R * 2 / 8)} y1={cy - R} x2={cx - R + i * (R * 2 / 8)} y2={cy + R}
            stroke="#00e5ff" strokeWidth="0.4" />
        ))}
        {/* latitude arcs */}
        {[-60, -30, 0, 30, 60].map((angle, i) => {
          const ry = R * Math.cos(angle * Math.PI / 180);
          const y = cy + R * Math.sin(angle * Math.PI / 180);
          return <ellipse key={`lat${i}`} cx={cx} cy={y} rx={ry} ry={ry * 0.18} fill="none" stroke="#00ffd0" strokeWidth="0.5" strokeOpacity="0.6" />;
        })}
        {/* meridian arcs */}
        {[0, 45, 90, 135].map((angle, i) => (
          <ellipse key={`mer${i}`} cx={cx} cy={cy} rx={R * 0.15} ry={R} fill="none"
            stroke="#7c4dff" strokeWidth="0.5" strokeOpacity="0.5"
            style={{ transform: `rotate(${angle}deg)`, transformOrigin: `${cx}px ${cy}px` }} />
        ))}
      </g>

      {/* ── Main sphere body ── */}
      <circle cx={cx} cy={cy} r={R - 5} fill="url(#bio-sphere-grad)" />
      <circle cx={cx} cy={cy} r={R - 5} fill="url(#bio-membrane-grad)"
        className="bio-breathe" style={{ transformOrigin: `${cx}px ${cy}px` }} />

      {/* ── Bio-luminescent vein network ── */}
      <g filter="url(#bio-plasma)" opacity="0.85">
        {CITIES.map((city, i) => (
          <path key={i}
            d={`M${cx},${cy} Q${(cx + city.cx) / 2 + (Math.random() - 0.5) * 40},${(cy + city.cy) / 2 + (Math.random() - 0.5) * 40} ${city.cx},${city.cy}`}
            fill="none"
            stroke={city.color}
            strokeWidth="1.4"
            strokeDasharray="6 5"
            style={{
              animation: `bio-neural-flash ${2 + i * 0.4}s ease-in-out ${city.delay}s infinite`,
              filter: `drop-shadow(0 0 4px ${city.color})`,
            }}
          />
        ))}
      </g>

      {/* ── DNA helix conduits (branching veins) ── */}
      <g opacity="0.5">
        <path d={`M${cx},${cy} C${cx - 60},${cy - 80} ${cx + 40},${cy - 120} ${cx - 20},${cy - 160}`}
          fill="none" stroke="url(#bio-vein-1)" strokeWidth="1.2" strokeDasharray="8 4"
          style={{ animation: 'bio-dna-helix-shift 2s linear infinite' }} />
        <path d={`M${cx},${cy} C${cx + 70},${cy - 40} ${cx + 110},${cy + 60} ${cx + 90},${cy + 130}`}
          fill="none" stroke="url(#bio-vein-2)" strokeWidth="1" strokeDasharray="6 5"
          style={{ animation: 'bio-dna-helix-shift 2.5s linear infinite reverse' }} />
        <path d={`M${cx},${cy} C${cx - 90},${cy + 50} ${cx - 70},${cy + 120} ${cx - 30},${cy + 155}`}
          fill="none" stroke="url(#bio-vein-3)" strokeWidth="1" strokeDasharray="7 4"
          style={{ animation: 'bio-dna-helix-shift 3s linear infinite' }} />
      </g>

      {/* ── Bio-scan sweep ── */}
      <g style={{ transformOrigin: `${cx}px ${cy}px`, animation: 'bio-scan-sweep 10s linear infinite' }}>
        <path d={`M${cx},${cy} L${cx + R - 5},${cy} A${R - 5},${R - 5} 0 0,1 ${cx + (R - 5) * Math.cos(60 * Math.PI / 180)},${cy + (R - 5) * Math.sin(60 * Math.PI / 180)} Z`}
          fill="url(#bio-scan-grad)" opacity="0.25" />
      </g>

      {/* ── Sphere highlight (specular) ── */}
      <ellipse cx={cx - R * 0.25} cy={cy - R * 0.3} rx={R * 0.28} ry={R * 0.16}
        fill="white" opacity="0.07" style={{ filter: 'blur(8px)' }} />

      {/* ── Sphere border (membrane) ── */}
      <circle cx={cx} cy={cy} r={R - 5} fill="none"
        stroke="#00ffd0" strokeWidth="1.5" strokeOpacity="0.4"
        style={{ animation: 'bio-heartbeat 1.8s ease-in-out infinite', transformOrigin: `${cx}px ${cy}px` }}
      />

      {/* ── Core pulsing heart ── */}
      <circle cx={cx} cy={cy} r={28} fill="url(#bio-core-grad)"
        className="bio-heartbeat" style={{ transformOrigin: `${cx}px ${cy}px` }} />
      <circle cx={cx} cy={cy} r={14} fill="#aaffee"
        style={{ opacity: 0.9, filter: 'blur(3px)', animation: 'bio-heartbeat 1.8s ease-in-out 0.1s infinite', transformOrigin: `${cx}px ${cy}px` }} />

      {/* ── Live metric inside core ── */}
      <text x={cx} y={cy - 8} textAnchor="middle" fill="#00ffd0"
        fontSize="13" fontWeight="900" letterSpacing="1"
        style={{ animation: 'bio-number-throb 2s ease-in-out infinite', filter: 'drop-shadow(0 0 8px #00ffd0)' }}>
        {liveMetric.toLocaleString()}
      </text>
      <text x={cx} y={cy + 6} textAnchor="middle" fill="rgba(0,255,208,0.55)" fontSize="6" fontWeight="bold" letterSpacing="4">
        DATA/SEC
      </text>

      {/* ── City neural nodes ── */}
      {CITIES.map((city, i) => (
        <g key={i}>
          {/* Synaptic ping rings */}
          <circle cx={city.cx} cy={city.cy} r={3} fill={city.color} opacity="0.9"
            style={{ filter: `drop-shadow(0 0 5px ${city.color})` }} />
          <circle cx={city.cx} cy={city.cy} r={3} fill="none" stroke={city.color} strokeWidth="1"
            style={{ animation: `bio-city-ping 2s ease-out ${city.delay}s infinite` }} />
          <circle cx={city.cx} cy={city.cy} r={3} fill="none" stroke={city.color} strokeWidth="0.5"
            style={{ animation: `bio-city-ping 2s ease-out ${city.delay + 0.4}s infinite` }} />
          {/* City label */}
          <text x={city.cx} y={city.cy - 10} textAnchor="middle" fill={city.color}
            fontSize="7.5" fontWeight="bold" letterSpacing="1"
            style={{ filter: `drop-shadow(0 0 4px ${city.color})` }}>
            {city.name}
          </text>
          {/* Synaptic spark flash */}
          {synapseCities.includes(i) && (
            <circle cx={city.cx} cy={city.cy} r={2} fill="white" opacity="0.9"
              style={{ animation: 'bio-synapse 0.5s ease-out forwards' }} />
          )}
        </g>
      ))}
    </svg>
  );
};

/* ═══════════════════════════════════════════════════════════
   VITALITY GAUGE — organic breathing gauge
   ═══════════════════════════════════════════════════════════ */
const VitalityGauge = ({ score }: { score: number }) => {
  const pct = Math.min(100, Math.max(0, score));
  const angle = -135 + (pct / 100) * 270;
  const r = 52, cx = 64, cy = 64;
  const arcLen = 2 * Math.PI * r * (270 / 360);
  const filled = arcLen * (pct / 100);

  return (
    <div className="flex flex-col items-center gap-1">
      <svg viewBox="0 0 128 100" className="w-28 h-22" style={{ overflow: 'visible' }}>
        <defs>
          <linearGradient id="gauge-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stopColor="#00ffa0" />
            <stop offset="50%" stopColor="#00e5ff" />
            <stop offset="100%" stopColor="#7c4dff" />
          </linearGradient>
          <filter id="gauge-glow">
            <feGaussianBlur stdDeviation="2.5" result="blur" />
            <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
          </filter>
        </defs>
        {/* Track */}
        <circle cx={cx} cy={cy} r={r} fill="none"
          stroke="rgba(0,255,160,0.1)" strokeWidth="8"
          strokeDasharray={`${arcLen} 999`}
          strokeDashoffset={-arcLen * (45 / 360) * (360 / 270)}
          strokeLinecap="round"
          transform={`rotate(-225 ${cx} ${cy})`} />
        {/* Filled arc */}
        <circle cx={cx} cy={cy} r={r} fill="none"
          stroke="url(#gauge-grad)" strokeWidth="8"
          strokeDasharray={`${filled} 999`}
          strokeDashoffset={-arcLen * (45 / 360) * (360 / 270)}
          strokeLinecap="round"
          filter="url(#gauge-glow)"
          transform={`rotate(-225 ${cx} ${cy})`}
          style={{ animation: 'bio-gauge-expand 1.8s ease-in-out infinite', transformOrigin: `${cx}px ${cy}px` }} />
        {/* Needle */}
        <line
          x1={cx} y1={cy}
          x2={cx + r * 0.7 * Math.cos((angle - 90) * Math.PI / 180)}
          y2={cy + r * 0.7 * Math.sin((angle - 90) * Math.PI / 180)}
          stroke="#00ffa0" strokeWidth="2" strokeLinecap="round"
          style={{ filter: 'drop-shadow(0 0 5px #00ffa0)', animation: 'bio-vitality-pulse 1.8s ease-in-out infinite' }}
        />
        <circle cx={cx} cy={cy} r={5} fill="#00ffa0" style={{ filter: 'drop-shadow(0 0 8px #00ffa0)' }} />
        {/* Score value */}
        <text x={cx} y={cy + 24} textAnchor="middle" fill="#00ffa0" fontSize="20" fontWeight="900"
          style={{ filter: 'drop-shadow(0 0 8px #00ffa0aa)', animation: 'bio-number-throb 1.8s ease-in-out infinite' }}>
          {score}
        </text>
        <text x={cx} y={cy + 34} textAnchor="middle" fill="rgba(0,255,160,0.5)" fontSize="6" letterSpacing="3">
          VITALITY
        </text>
      </svg>
    </div>
  );
};

/* ═══════════════════════════════════════════════════════════
   MODULE CARD — bio-petri dish
   ═══════════════════════════════════════════════════════════ */
const BioModule = ({ label, desc, route, color, delay }: {
  label: string; desc: string; route: string; color: string; delay: string;
}) => {
  // 🟢 效能優化：快取隨機係數防止 40ms 高頻重繪時微幅抖動與 CPU 耗損
  const rnd = React.useMemo(() => ({
    floatDur: 5 + Math.random() * 2,
    breatheDur: 3 + Math.random(),
    pts: Array.from({ length: 5 }, (_, i) => ({
      x: (10 + Math.random() * 80) + '%',
      y: (20 + Math.random() * 60) + '%',
      delay: `${i * 0.7 + Math.random()}s`
    }))
  }), []);

  return (
    <Link to={route}
      className="relative overflow-hidden rounded-2xl flex flex-col items-start gap-3 p-4 group transition-all duration-300 hover:-translate-y-2"
      style={{
        background: `radial-gradient(circle at 30% 20%, ${color}18 0%, ${color}06 50%, transparent 80%),
          linear-gradient(135deg, rgba(0,20,30,0.85) 0%, rgba(0,10,20,0.95) 100%)`,
        border: `1px solid ${color}30`,
        animation: `bio-petri-float ${rnd.floatDur}s ease-in-out ${delay} infinite`,
        boxShadow: `0 4px 30px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05)`,
      }}>
      {/* Bio-membrane shimmer top */}
      <div className="absolute inset-x-0 top-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        style={{ background: `linear-gradient(90deg, transparent, ${color}80, transparent)` }} />
      {/* Particle swarm background */}
      <div className="absolute inset-0 pointer-events-none overflow-hidden rounded-2xl">
        {rnd.pts.map((p, i) => (
          <BioParticle key={i}
            x={p.x as any}
            y={p.y as any}
            color={color}
            delay={p.delay}
          />
        ))}
      </div>
    {/* Circular bio-glow icon */}
    <div className="relative w-10 h-10 rounded-full flex items-center justify-center z-10 transition-transform duration-300 group-hover:scale-110"
      style={{
        background: `radial-gradient(circle at 35% 35%, ${color}40, ${color}10)`,
        border: `1px solid ${color}50`,
        boxShadow: `0 0 20px ${color}30, inset 0 0 10px ${color}15`,
        animation: `bio-breathe ${rnd.breatheDur}s ease-in-out ${delay} infinite`,
      }}>
      <div className="w-3 h-3 rounded-full" style={{ background: color, boxShadow: `0 0 8px ${color}` }} />
    </div>
    <div className="z-10">
      <p className="text-sm font-black tracking-wide transition-colors duration-300 group-hover:brightness-125"
        style={{ color, textShadow: `0 0 10px ${color}60` }}>
        {label}
      </p>
      <p className="text-[11px] mt-0.5 font-medium" style={{ color: 'rgba(180,220,230,0.5)' }}>{desc}</p>
    </div>
    {/* Corner membrane decoration */}
    <div className="absolute bottom-0 right-0 w-16 h-16 rounded-full pointer-events-none opacity-20"
      style={{
        background: `radial-gradient(circle at 70% 70%, ${color}, transparent 70%)`,
        filter: 'blur(10px)',
      }} />
  </Link>
  );
};

/* ═══════════════════════════════════════════════════════════
   MAIN PAGE
   ═══════════════════════════════════════════════════════════ */
